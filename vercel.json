{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    {
      "src": "/api/script_api.js",
      "dest": "/api/script_api.js"
    },
    {
      "src": "/index.html",
      "dest": "/index.html"
    },
    {
      "src": "/api/login.php",
      "dest": "/api/login.php"
    },
    {
      "src": "/api/register.php",
      "dest": "/api/register.php"
    },
    {
      "src": "/api/dashboard.php",
      "dest": "/api/dashboard.php"
    },
    {
      "src": "/api/kasir_dashboard.php",
      "dest": "/api/kasir_dashboard.php"
    },
    {
      "src": "/api/pending.php",
      "dest": "/api/pending.php"
    },
    {
      "src": "/api/logout.php",
      "dest": "/api/logout.php"
    },
    {
      "src": "/api/(.*)\\.php",
      "dest": "/api/$1.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/$1.php"
    }
  ]
}