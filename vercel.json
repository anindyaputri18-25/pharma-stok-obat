{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2"
    },
    "*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)\\.php",
      "dest": "/api/$1.php"
    },
    {
      "src": "/api/script_api.js",
      "dest": "/api/script_api.js"
    },
    {
      "src": "/api/([^./]+)$",
      "dest": "/api/$1.php"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/login",
      "dest": "/login.php"
    },
    {
      "src": "/register",
      "dest": "/register.php"
    },
    {
      "src": "/dashboard",
      "dest": "/dashboard.php"
    },
    {
      "src": "/(.*)\\.php",
      "dest": "/$1.php"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}