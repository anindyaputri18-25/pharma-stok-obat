{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)\\.php",
      "dest": "/api/$1.php"
    },
    {
      "src": "/api/script_api.js",
      "dest": "/api/script_api.js"
    },
    {
      "src": "/api/([^./]+)$",
      "dest": "/api/$1.php"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/api/$1"
    }
  ]
}